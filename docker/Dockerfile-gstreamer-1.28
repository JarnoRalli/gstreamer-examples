# Use Ubuntu 24.04 as the building base
FROM ubuntu:24.04

ENV DEBIAN_FRONTEND=noninteractive

# Install dependencies
RUN apt-get update && apt-get install -y \
    build-essential \
    git \
    python3 \
    python3-pip \
    ninja-build \
    flex \
    bison \
    curl \
    cmake \
    pkg-config \
    libssl-dev \
    libglib2.0-dev \
    libasound2-dev \
    libpulse-dev \
    libv4l-dev \
    libxv-dev \
    libx11-dev \
    nasm \
    yasm \
    libgl1-mesa-dev \
    libegl1-mesa-dev \
    libgles2-mesa-dev \
    vulkan-tools \
    libvulkan-dev \
    mesa-vulkan-drivers \
    libclang-dev \
    llvm \
    libsoup-3.0-dev \
    libcairo2-dev \
    libpango1.0-dev \
    libvulkan1 \
    vulkan-validationlayers \
    libdrm-dev \
    libpciaccess-dev \
    python3-dev \
    gobject-introspection \
    libgirepository1.0-dev \
    libx264-dev \
    libx265-dev \
    libvpx-dev \
    libopus-dev \
    libvorbis-dev \
    libogg-dev \
    libtheora-dev \
    libfdk-aac-dev \
    libavcodec-dev \
    libavformat-dev \
    libavfilter-dev \
    libswscale-dev \
    && rm -rf /var/lib/apt/lists/*

# Install modern Meson
RUN pip3 install --break-system-packages meson pygobject supervision

# Install Rust toolchain
RUN curl --proto '=https' --tlsv1.2 -sSf https://sh.rustup.rs | sh -s -- -y
ENV PATH="/root/.cargo/bin:${PATH}"

# Install cargo-c
RUN cargo install cargo-c

WORKDIR /opt
RUN git clone https://gitlab.freedesktop.org/gstreamer/gstreamer.git --depth 1 --branch 1.28.4

WORKDIR /opt/gstreamer

# =========================================================================
# MANUAL CLONE AND MODIFICATION OF GST-PLUGINS-RS
# =========================================================================
# 1. Directly clone the matching 1.28.4 tag of gst-plugins-rs into subprojects
RUN git clone --depth 1 --branch gstreamer-1.28.4 https://gitlab.freedesktop.org/gstreamer/gst-plugins-rs.git subprojects/gst-plugins-rs

# 2. Modify Cargo.toml of the burn plugin to add "vulkan" as a backend
RUN sed -i 's/default = \["pretrained", "ndarray"\]/default = \["pretrained", "ndarray", "vulkan"\]/g' subprojects/gst-plugins-rs/analytics/burn/Cargo.toml
# =========================================================================

# Configure and build
RUN meson setup build \
    --buildtype=release \
    -Drs=enabled \
    -Dprefix=/usr/local \
    -Dtests=disabled \
    -Dexamples=disabled \
    -Ddoc=disabled \
    -Dintrospection=enabled \
    -Dpython=enabled \
    -Dgst-plugins-bad:gl=enabled \
    -Dgst-plugins-base:gl=enabled \
    -Dgpl=enabled \
    && meson compile -C build \
    && meson install -C build

# Set environment variables absolutely
ENV GST_PLUGIN_PATH=/usr/local/lib/x86_64-linux-gnu/gstreamer-1.0
ENV LD_LIBRARY_PATH=/usr/local/lib/x86_64-linux-gnu

# Discover GStreamer bindings
ENV PYTHONPATH=/usr/local/lib/python3/dist-packages:/usr/local/lib/python3.12/site-packages
ENV GI_TYPELIB_PATH=/usr/local/lib/x86_64-linux-gnu/girepository-1.0

# Install FastAPI and Uvicorn for GStreamer MCP doc-agent
RUN pip3 install --break-system-packages fastapi uvicorn

# Verify the installation on startup
WORKDIR /workspace
CMD ["gst-inspect-1.0", "--version"]
